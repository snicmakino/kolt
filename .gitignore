# Gradle
.gradle/
/build/
**/build/
!gradle/wrapper/gradle-wrapper.jar
# `**/build/` is meant to ignore Gradle output in subprojects, but it
# also matches the kolt source domain package at src/**/kolt/build/.
# Re-include those explicitly so new files there can be tracked.
!src/**/kolt/build/
!src/**/kolt/build/**

# assemble-dist.sh release staging
/dist/

# IDE
.idea/
*.iml
*.ipr
*.iws

# Kotlin/Native
.konan/

# OS
.DS_Store

# Database
*.db

# LSP workspace files (generated by kolt)
workspace.json
kls-classpath

# Claude Code
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Spike fixtures (regenerate via gen.sh)
spike/**/fixtures/

# Exclude zigpj directory
zigpj/
.takt/
